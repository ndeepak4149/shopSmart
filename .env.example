# ── AI ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Search APIs ────────────────────────────────────────────────────────────────
CHANNEL3_API_KEY=...
SERP_API_KEY=...           # SerpAPI — used for Google Shopping results
GOOGLE_PLACES_API_KEY=...  # Google Places — local store search + place details

# ── Database ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...        # use the anon/public key
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── Email alerts ───────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Reddit (pending approval) ──────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ShopSmart/1.0

# ── Misc ───────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
APP_ENV=development        # set to "production" on Railway

# ── Frontend (Next.js) ─────────────────────────────────────────────────────────
# Put this in frontend/.env.local
NEXT_PUBLIC_API_URL=https://your-backend.railway.app
